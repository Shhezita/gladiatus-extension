{
  "manifest_version": 3,
  "name": "Gladiatus Auction Sorter",
  "description": "Sort visible Gladiatus auction house items by parsed tooltip stats.",
  "version": "0.1.0",
  "permissions": ["activeTab", "storage"],
  "action": {
    "default_title": "Gladiatus Auction Scanner",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://*.gladiatus.gameforge.com/game/*"],
      "js": ["auction-schema.js", "auction-core.js"],
      "run_at": "document_idle",
      "world": "MAIN"
    },
    {
      "matches": ["https://*.gladiatus.gameforge.com/game/*"],
      "js": ["auction-schema.js", "auction-model.js", "auction-core.js", "content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["auction-schema.js", "auction-core.js"],
      "matches": ["https://*.gladiatus.gameforge.com/*"]
    }
  ]
}
